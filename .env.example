# Application
APP_NAME=CyberArena
APP_VERSION=0.1.0
# environment: development | production | testing
ENVIRONMENT=development
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Server
HOST=0.0.0.0
PORT=8000

# Database
# SQLite (default for development):
DATABASE_URL=sqlite:///./cyberarena.db
# PostgreSQL (production / docker-compose):
# DATABASE_URL=postgresql+psycopg2://cyberarena:cyberarena@db:5432/cyberarena
DATABASE_ECHO=false

# Sessions
SESSION_COOKIE_NAME=cyberarena_session
# Session lifetime in seconds (default: 8 hours)
SESSION_MAX_AGE=28800

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/cyberarena.log
